require_once 'config.inc';
require_once 'util.inc';

/*
 * Legacy CARP service-failure demotion shim.
 *
 * On FreeBSD this aggregated the rc.carp_service_status.d checks and raised the
 * net.inet.carp.demotion sysctl so a failed service made the node lose the CARP
 * election. Linux/keepalived has no demotion sysctl; the very same checks are
 * now evaluated directly by keepalived through the carp_service_status
 * track_script generated by vrrp.inc, which moves the VRRP instance to FAULT
 * (releasing the virtual IPs to a healthy peer) when any check fails and lets
 * the node rejoin the election once they recover. There is therefore nothing
 * to do here. The configd action (update.carp.service_status) is kept as an
 * inert no-op so any remaining caller does not error.
 */
openlog("carp", LOG_ODELAY, LOG_DAEMON);
syslog(LOG_DEBUG, "carp service-failure demotion is handled by the keepalived track_script; nothing to do");
closelog();
