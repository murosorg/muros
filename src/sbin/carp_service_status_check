#!/bin/sh

# MurOS keepalived track_script helper.
#
# keepalived runs this on a fixed interval for every VRRP instance (see the
# track_script block generated by vrrp.inc). It returns non-zero when any
# registered CARP service check reports its service as unhealthy, which makes
# keepalived move the instance to the FAULT state so a healthy peer takes over
# the virtual IPs; once every check passes again the node rejoins the election.
#
# This replaces the FreeBSD net.inet.carp.demotion sysctl mechanism (which has
# no Linux equivalent). Each executable dropped into the checks directory by a
# subsystem must exit non-zero when its service is down, zero otherwise. An
# empty directory means nothing to monitor, so the node stays eligible.

CHECK_DIR=/usr/local/etc/rc.carp_service_status.d

status=0
for check in "$CHECK_DIR"/*; do
    [ -f "$check" ] && [ -x "$check" ] || continue
    if ! "$check" >/dev/null 2>&1; then
        status=1
    fi
done

exit $status
