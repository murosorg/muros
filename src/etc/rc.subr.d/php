OWNERSHIP=$(opnsense-version -R 'CORE_GROUP=CORE_GID:CORE_USER=CORE_UID')
OWNERGRP=${OWNERSHIP%:*}
OWNERUSR=${OWNERSHIP##*:}

GROUP=${OWNERGRP%=*}
GID=${OWNERGRP##*=}
USER=${OWNERUSR%=*}
UID=${OWNERUSR##*=}
OWNER="${USER}:${GROUP}"

# Ensure the web group exists (Debian shadow utilities). The default MurOS
# web identity maps onto Debian's stock www-data (uid/gid 33), which already
# exists, so this is a no-op on a standard system; we only create it when a
# custom group/uid was configured. We never force-change an existing system
# group's gid to avoid disrupting other services that share it.
if ! getent group "${GROUP}" >/dev/null 2>&1; then
    groupadd -g "${GID}" "${GROUP}" 2>/dev/null || groupadd "${GROUP}"
fi

# Ensure the web user exists and is a non-login, no-home service account.
if ! getent passwd "${USER}" >/dev/null 2>&1; then
    useradd -u "${UID}" -g "${GROUP}" -c "World Wide Web Only" \
        -d /nonexistent -s /usr/sbin/nologin "${USER}" 2>/dev/null || \
    useradd -g "${GROUP}" -c "World Wide Web Only" \
        -d /nonexistent -s /usr/sbin/nologin "${USER}"
fi

# set up required output directories for various PHP components
for _PHPDIR in cache sessions tests tmp; do
	PHPDIR=/var/lib/php/${_PHPDIR}

	mkdir -p ${PHPDIR}
	if [ "${_PHPDIR}" = "tmp" ]; then
		# special permission here
		chmod 01777 ${PHPDIR}
	else
		chmod 750 ${PHPDIR}
	fi

	chown -R ${OWNER} ${PHPDIR}
done

# ensure that "other" can access the tmp dir later on
chmod 755 /var/lib /var/lib/php

# change ownership for GUI related file access
mkdir -p /conf/backup
find /conf -name 'vouchers_*.db' -exec chown ${OWNER} {} \;
find /conf/backup -name '*.xml' -exec chown ${OWNER} {} \;
for PHPOWN in /conf /conf/config.xml /conf/backup /var/run/booting; do
	if [ -e ${PHPOWN} ]; then
		chown ${OWNER} ${PHPOWN}
	fi
done

# flush Phalcon volt templates
find /var/lib/php/cache -name '*.php' -delete
