#
# MurOS system-wide PAM defaults (Linux-PAM)
#

# auth
auth		sufficient	pam_exec.so	expose_authtok quiet /usr/bin/php /usr/local/libexec/opnsense-pam-exec
auth		required	pam_unix.so	try_first_pass nullok

# account
account		required	pam_unix.so

# session
session		required	pam_unix.so

# password
password	required	pam_unix.so	try_first_pass
