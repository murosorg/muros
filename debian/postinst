#!/bin/sh
set -e
case "$1" in
  configure)
    # Take over the php-fpm www pool with the MurOS-sized pool.
    if [ ! -e /etc/php/8.4/fpm/pool.d/www.conf.distrib ]; then
      dpkg-divert --package muros --add --rename \
        --divert /etc/php/8.4/fpm/pool.d/www.conf.distrib \
        /etc/php/8.4/fpm/pool.d/www.conf || true
    fi

    # Self-signed certificate for the web UI (replace later from the GUI).
    if [ ! -s /usr/local/etc/muros/server.crt ] || [ ! -s /usr/local/etc/muros/server.key ]; then
      mkdir -p /usr/local/etc/muros
      openssl req -x509 -newkey rsa:2048 -nodes -days 3650 \
        -keyout /usr/local/etc/muros/server.key \
        -out /usr/local/etc/muros/server.crt \
        -subj '/O=MurOS/CN=MurOS' >/dev/null 2>&1 || true
      chown www-data:www-data /usr/local/etc/muros/server.crt /usr/local/etc/muros/server.key 2>/dev/null || true
      chmod 600 /usr/local/etc/muros/server.key 2>/dev/null || true
    fi

    # Seed a default configuration so the control plane and UI can start.
    if [ ! -e /conf/config.xml ] && [ -e /usr/local/etc/config.xml.sample ]; then
      mkdir -p /conf
      cp -p /usr/local/etc/config.xml.sample /conf/config.xml
      chown www-data:www-data /conf/config.xml 2>/dev/null || true
      chmod 640 /conf/config.xml 2>/dev/null || true
    fi
    if [ ! -e /usr/local/etc/config.xml ]; then
      ln -sf /conf/config.xml /usr/local/etc/config.xml
    fi

    # PHP runtime directories referenced by 99-muros.ini.
    for d in /var/lib/php/tmp /var/lib/php/sessions; do
      mkdir -p "$d"
      chown www-data:www-data "$d" 2>/dev/null || true
      chmod 700 "$d" 2>/dev/null || true
    done

    # Pick up the lighttpd drop-in and (re)start the front end.
    systemctl daemon-reload 2>/dev/null || true
    systemctl reload-or-restart php8.4-fpm 2>/dev/null || true
    systemctl restart lighttpd 2>/dev/null || true
    ;;
esac
#DEBHELPER#
exit 0
