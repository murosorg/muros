#!/bin/sh
set -e
case "$1" in
  remove|purge)
    if dpkg-divert --list /etc/php/8.4/fpm/pool.d/www.conf 2>/dev/null | grep -q muros; then
      dpkg-divert --package muros --remove --rename \
        --divert /etc/php/8.4/fpm/pool.d/www.conf.distrib \
        /etc/php/8.4/fpm/pool.d/www.conf || true
    fi
    # The credential-sync pam-config file has been removed by dpkg at this
    # point; regenerate the PAM stacks so its optional hook is dropped from
    # /etc/pam.d/common-password.
    if command -v pam-auth-update >/dev/null 2>&1; then
      DEBIAN_FRONTEND=noninteractive pam-auth-update --package >/dev/null 2>&1 || true
    fi
    ;;
esac
case "$1" in
  purge)
    # drop the journald sizing/persistence drop-in installed by postinst
    rm -f /etc/systemd/journald.conf.d/muros.conf
    rmdir /etc/systemd/journald.conf.d 2>/dev/null || true
    ;;
esac
#DEBHELPER#
exit 0
