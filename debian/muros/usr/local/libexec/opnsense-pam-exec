#!/usr/bin/php
<?php

/*
 * Copyright (C) 2026 MurOS
 * All rights reserved.
 *
 * Linux-PAM bridge for pam_exec.so.
 *
 * On Debian the FreeBSD pam_opnsense.so module is not available. Instead the
 * stock pam_exec.so module invokes this helper: the authenticating user is
 * passed in the PAM_USER environment variable and, when pam_exec is configured
 * with expose_authtok, the password is provided on stdin. We translate that
 * into the null-separated key/value protocol understood by opnsense-auth and
 * return its exit status, so the operating system (console, sshd, ...)
 * authenticates against the MurOS user backends.
 */

$user = getenv('PAM_USER');
$service = getenv('PAM_SERVICE');
$type = getenv('PAM_TYPE');

if ($user === false || $user === '') {
    exit(255);
}
if ($service === false || $service === '') {
    $service = 'system';
}

$password = '';
if ($type === 'auth' || $type === '' || $type === false) {
    $line = fgets(STDIN);
    if ($line !== false) {
        $password = rtrim($line, "\r\n");
    }
}

$descriptors = array(
    0 => array('pipe', 'r'),
    1 => array('pipe', 'w'),
    2 => array('pipe', 'w'),
);

/* invoke opnsense-auth through the very same PHP binary so we never depend on
 * the PATH, which PAM strips down to almost nothing. */
$process = proc_open(array(PHP_BINARY, '/usr/local/libexec/opnsense-auth'), $descriptors, $pipes);
if (!is_resource($process)) {
    exit(255);
}

fwrite($pipes[0], sprintf("user=%s\0password=%s\0service=%s\0\0", $user, $password, $service));
fclose($pipes[0]);
stream_get_contents($pipes[1]);
fclose($pipes[1]);
stream_get_contents($pipes[2]);
fclose($pipes[2]);

exit(proc_close($process));
