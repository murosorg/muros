Depends: lighttpd, php8.4-fpm, php8.4-cli, php8.4-ctype, php8.4-curl, php8.4-xml, php8.4-gd, php8.4-mbstring, php8.4-bcmath, php8.4-ldap, php8.4-sqlite3, php8.4-phalcon, python3 (>= 3.11), python3-jinja2, python3-dnspython, python3-ldap3, nftables, iproute2, chrony
