#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_clean:
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:

override_dh_auto_install:
	debian/stage-fs.sh debian/muros

# Appliance package: ships the OPNsense layout under /usr/local on purpose.
override_dh_usrlocal:

# Keep source file modes (configd ships its own executables).
override_dh_fixperms:

# Units are placed under /lib/systemd/system by stage-fs.sh.
override_dh_installsystemd:
	# The configd control plane backs the whole web UI: the dashboard widgets
	# and every settings-apply action talk to it over its unix socket. It must
	# be enabled AND running after install and after every upgrade, otherwise
	# the UI hangs on the client connect timeout and every widget fails to load.
	# It only listens on a local socket, so starting it never touches the
	# management link. dh_installsystemd (no --no-start) enables it, starts it on
	# install and restarts it on upgrade.
	dh_installsystemd --name=muros-configd muros-configd.service
	# Data-plane units (interface assignment, addressing, firewall) are shipped
	# but left disabled: they are opt-in and must never touch the management
	# link or lock the operator out before interfaces have been assigned.
	dh_installsystemd --name=muros-firewall --no-enable --no-start muros-firewall.service
	dh_installsystemd --name=muros-interface-assign --no-enable --no-start muros-interface-assign.service
	dh_installsystemd --name=muros-interfaces --no-enable --no-start muros-interfaces.service
	# CARP/VRRP bring-up. Shipped disabled here and enabled through the systemd
	# preset (90-muros.preset) alongside the other data-plane units, so it never
	# auto-starts at install before interfaces have been assigned.
	dh_installsystemd --name=muros-carp --no-enable --no-start muros-carp.service

# Large interpreted payload: these steps are irrelevant and slow.
override_dh_strip:
override_dh_shlibdeps:
override_dh_dwz:
